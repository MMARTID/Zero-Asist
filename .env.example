# ══════════════════════════════════════════════════════════════════
# Zero-Asist — Variables de entorno
# Copia este archivo y rellena los valores reales:
#   cp .env.example backend/.env
#   cp .env.example frontend/.env.local  (solo las NEXT_PUBLIC_*)
# ══════════════════════════════════════════════════════════════════

# ── Backend ──────────────────────────────────────────────────────

# Google Gemini (extracción con IA)
GEMINI_API_KEY=

# OAuth2 Gmail (flujo de onboarding)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
OAUTH_CLIENT_CONFIG_PATH=oauth_client_config.json

# Google Cloud
CLOUD_RUN_URL=
GMAIL_PUBSUB_TOPIC=

# Google Cloud (Firestore) — en local apunta al fichero de credenciales
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/credenciales.json

# Autenticación del scheduler
# SCHEDULER_DEV_TOKEN=mi_token_secreto_local
# SCHEDULER_AUDIENCE=https://tu-servicio.run.app

# ── Frontend ─────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
